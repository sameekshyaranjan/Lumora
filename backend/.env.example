# Server
PORT=5000
NODE_ENV=development

# CORS — must equal the frontend dev origin exactly (Vite default is 5173)
FRONTEND_ORIGIN=http://localhost:5173

# PostgreSQL (Neon or Supabase). Neon usually needs sslmode=require.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# A SEPARATE database/branch used only by the test suite (Stage 10).
# If you only have one DB, point this at the same URL — tests truncate tables.
TEST_DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME_test?sslmode=require

# Auth secrets — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_me_with_long_random_string
REFRESH_TOKEN_SECRET=replace_me_with_a_DIFFERENT_long_random_string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Where the refresh cookie is valid. In dev the refresh route lives under /auth.
REFRESH_COOKIE_PATH=/auth
